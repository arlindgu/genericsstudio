---
import { useTranslations } from "@/i18n/utils";

interface Props { locale?: string }
const { locale = "de" } = Astro.props;
const { tRaw } = useTranslations(locale);

type Step = { number: string; title: string; description: string };
type FeaturesContent = { heading: string; description: string; steps: Step[] };
const c = tRaw<FeaturesContent>("sections.branding.features");
---

<section class="px-6 md:px-10 border-t border-white/6">
  <div class="max-w-7xl mx-auto">

    <div class="py-28 flex flex-col lg:flex-row lg:justify-between gap-8 lg:gap-16">
      <h2 class="text-section-heading fw-510 leading-[1.08] tracking-[-0.04em] text-foreground lg:max-w-[44%]">
        {c.heading}
      </h2>
      <p class="text-body text-muted-foreground leading-[1.7] fw-400 lg:max-w-[42%] flex items-center">
        {c.description}
      </p>
    </div>

    <div class="border-t border-white/6">
      {c.steps.map((step) => (
        <div class="flex items-start gap-8 py-10 border-b border-white/6">
          <div class="flex flex-col lg:flex-row lg:justify-between flex-1">
            <h3 class="text-step-heading fw-510 text-foreground tracking-[-0.03em] leading-tight lg:w-72 flex-shrink-0 mb-4 lg:mb-0">
              {step.title}
            </h3>
            <p class="text-body text-muted-foreground leading-[1.75] fw-400 flex-1 max-w-2xl">{step.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
