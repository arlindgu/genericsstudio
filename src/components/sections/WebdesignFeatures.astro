---
import { useTranslations } from "@/i18n/utils";

interface Props { locale?: string }
const { locale = "de" } = Astro.props;
const { tRaw } = useTranslations(locale);

type Stat = { value: string; label: string };
type Item = { number: string; title: string; description: string };
type FeaturesContent = { heading: string; description: string; stats: Stat[]; items: Item[] };
const c = tRaw<FeaturesContent>("sections.webdesign.features");

const icons: Record<string, string> = {
  "01": `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  "02": `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  "03": `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  "04": `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><line x1="12" y1="21" x2="20" y2="21"/></svg>`,
  "05": `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>`,
  "06": `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
};
---

<section class="px-6 md:px-10 border-t border-white/6">
  <div class="max-w-7xl mx-auto flex flex-col gap-12">

    <div class="py-28 flex flex-col lg:flex-row lg:justify-between gap-6 lg:gap-16">
      <h2 class="text-section-heading fw-510 leading-[1.08] tracking-[-0.04em] text-foreground lg:max-w-[44%]">
        {c.heading}
      </h2>
      <p class="text-body text-muted-foreground leading-[1.7] fw-400 lg:max-w-[42%] flex items-center">
        {c.description}
      </p>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-3 mb-px">
      {c.stats.map((stat) => (
        <div class="px-8 py-10 place-self-center text-center">
          <p class="text-page-heading fw-510 text-foreground tracking-[-0.04em] leading-none mb-2">{stat.value}</p>
          <p class="text-label text-muted-foreground fw-400">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- 2-col features grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 mb-16 gap-x-24">
      {c.items.map((item) => (
        <div class="py-8 flex flex-col gap-4">
          <div
            class="w-8 h-8 rounded-lg flex items-center justify-center text-foreground"
            set:html={icons[item.number]}
          />
          <div>
            <h3 class="text-body fw-590 text-foreground tracking-[-0.015em] mb-2">{item.title}</h3>
            <p class="text-label text-muted-foreground leading-[1.7] fw-400">{item.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
