---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

const content = {
  de: {
    heading: "Was du bekommst.",
    description: "Kein Baukastensystem. Kein Plugin-Wirrwarr. Jede Website wird von Grund auf für dein Business entwickelt.",
    stats: [
      { value: "100", label: "Lighthouse Score" },
      { value: "< 1s", label: "Ladezeit" },
      { value: "0", label: "WordPress Plugins" },
    ],
    items: [
      { number: "01", title: "Blitzschnelle Ladezeiten", description: "Kein JavaScript-Overhead, keine ungenutzten Plugins. Statisch generiert, global ausgeliefert. Unter 1 Sekunde ist Standard." },
      { number: "02", title: "SEO von Anfang an", description: "Semantisches HTML, Schema.org, Sitemap, optimierte Meta-Tags und Core Web Vitals im grünen Bereich. Als Fundament, nicht als Nachgedanke." },
      { number: "03", title: "Sicherheit ohne Kompromisse", description: "Keine WordPress-Angriffsfläche, keine veralteten Plugins, kein öffentliches Admin-Panel. Keine Datenbank, die man angreifen kann." },
      { number: "04", title: "Vollständig responsiv", description: "Mobile-first und auf allen Gerätegrössen getestet. Kein generisches Breakpoint-Raster, sondern ein Layout, das für dein Design gemacht wurde." },
      { number: "05", title: "Einfache Inhaltsverwaltung", description: "Auf Wunsch mit Headless CMS verbunden. Texte, Bilder und Seiten selbst bearbeiten, ohne technische Kenntnisse, ohne uns anzurufen." },
      { number: "06", title: "Übergabe mit Dokumentation", description: "Hosting, Domain, CMS und Code gehören dir. Mit verständlicher Anleitung, damit du weisst, was du hast, und nie von uns abhängig bist." },
    ],
  },
  en: {
    heading: "What you get.",
    description: "No page builders. No plugin chaos. Every website is developed from scratch for your business.",
    stats: [
      { value: "100", label: "Lighthouse Score" },
      { value: "< 1s", label: "Load time" },
      { value: "0", label: "WordPress plugins" },
    ],
    items: [
      { number: "01", title: "Lightning-fast load times", description: "No JavaScript overhead, no unused plugins. Statically generated and globally delivered. Under 1 second is standard." },
      { number: "02", title: "SEO built in from day one", description: "Semantic HTML, Schema.org, sitemap, optimised meta tags, and green Core Web Vitals. As a foundation, not an afterthought." },
      { number: "03", title: "Security without compromise", description: "No WordPress attack surface, no outdated plugins, no public admin panel. No database to attack." },
      { number: "04", title: "Fully responsive", description: "Mobile-first and tested across all screen sizes. Not a generic breakpoint grid, but a layout made for your design." },
      { number: "05", title: "Simple content management", description: "Optionally connected to a headless CMS. Edit text, images, and pages yourself — no technical knowledge, no need to call us." },
      { number: "06", title: "Handover with documentation", description: "Hosting, domain, CMS, and code belong to you. With a clear guide so you know exactly what you have and are never dependent on us." },
    ],
  },
};

const c = locale === "de" ? content.de : content.en;
---

<section class="px-6 md:px-10 border-t border-[rgba(255,255,255,0.06)]">
  <div class="max-w-7xl mx-auto">

    <div class="py-20 flex flex-col lg:flex-row lg:justify-between gap-6 lg:gap-16">
      <h2 class="text-[clamp(1.75rem,3vw,2.5rem)] fw-510 leading-[1.08] tracking-[-0.04em] text-[#f7f8f8] lg:max-w-[44%]">
        {c.heading}
      </h2>
      <p class="text-[15px] text-[#8a8f98] leading-[1.7] fw-400 lg:max-w-[42%] flex items-center">
        {c.description}
      </p>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-3 gap-px bg-[rgba(255,255,255,0.06)] mb-px">
      {c.stats.map((stat) => (
        <div class="bg-[#08090a] px-8 py-10">
          <p class="text-[clamp(2rem,4vw,3rem)] fw-510 text-[#f7f8f8] tracking-[-0.04em] leading-none mb-2">{stat.value}</p>
          <p class="text-[13px] text-[#62666d] fw-400">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- 2-col features grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-[rgba(255,255,255,0.06)] mb-16">
      {c.items.map((item) => (
        <div class="bg-[#08090a] p-8 flex flex-col gap-4">
          <span class="text-[11px] fw-510 text-[#3d4047] tracking-[0.1em]">{item.number}</span>
          <div>
            <h3 class="text-[15px] fw-590 text-[#f7f8f8] tracking-[-0.015em] mb-2">{item.title}</h3>
            <p class="text-[13px] text-[#62666d] leading-[1.7] fw-400">{item.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
