---
import { useTranslations } from "@/i18n/utils";

interface Props { locale?: string }
const { locale = "de" } = Astro.props;
const { tRaw } = useTranslations(locale);

type ComparisonContent = {
  heading: string; description: string;
  labelA: string; labelB: string;
  captionA: string; captionB: string;
  perf: string; access: string; bp: string; seo: string;
};
const c = tRaw<ComparisonContent>("sections.webdesign.comparison");

const circ = 138.23;
function scoreCircle(score: number) {
  const color = score >= 90 ? "#0cce6b" : score >= 50 ? "#ffa400" : "#ff4e43";
  const offset = circ * (1 - score / 100);
  return { color, offset };
}

const wpScores = [42, 74, 67, 71];
const gsScores = [100, 98, 100, 100];
const labels   = [c.perf, c.access, c.bp, c.seo];
---

<section class="px-6 md:px-10">
  <div class="max-w-7xl mx-auto">

    <div class="py-28 flex flex-col lg:flex-row lg:justify-between gap-8 lg:gap-16">
      <h2 class="text-section-heading fw-510 leading-[1.08] tracking-[-0.04em] text-foreground lg:max-w-[44%]">
        {c.heading}
      </h2>
      <p class="text-body text-muted-foreground leading-[1.7] fw-400 lg:max-w-[42%] flex items-center">
        {c.description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-white/6 pt-10 pb-10">

      <!-- Panel A: WordPress -->
      <div>
        <div class="bg-surface rounded-[8px] p-6 mb-6 border border-white/5">
          <div class="flex items-center gap-2 mb-6 pb-4 border-b border-white/5">
            <div class="flex-1 h-5 rounded-[4px] bg-secondary flex items-center px-3">
            </div>
          </div>
          <div class="grid grid-cols-4 gap-3">
            {wpScores.map((score, i) => {
              const { color, offset } = scoreCircle(score);
              return (
                <div class="flex flex-col items-center gap-2">
                  <svg viewBox="0 0 50 50" class="w-12 h-12">
                    <circle cx="25" cy="25" r="22" fill="none" stroke="rgb(255 255 255 / 5%)" stroke-width="3.5"/>
                    <circle cx="25" cy="25" r="22" fill="none" stroke={color} stroke-width="3.5" stroke-dasharray={circ} stroke-dashoffset={offset} stroke-linecap="round" transform="rotate(-90 25 25)"/>
                    <text x="25" y="29" text-anchor="middle" fill={color} font-size="11" font-weight="600">{score}</text>
                  </svg>
                  <p class="text-label text-foreground-dimmer fw-400 text-center leading-tight">{labels[i]}</p>
                </div>
              );
            })}
          </div>
        </div>
        <h3 class="text-body fw-590 text-foreground tracking-[-0.015em] mb-2">{c.labelA}</h3>
        <p class="text-label text-muted-foreground leading-[1.65] fw-400">{c.captionA}</p>
      </div>

      <!-- Panel B: Generics Studio -->
      <div>
        <div class="bg-surface rounded-[8px] p-6 mb-6 border border-white/5">
          <div class="flex items-center gap-2 mb-6 pb-4 border-b border-white/5">
            <div class="flex-1 h-5 rounded-[4px] bg-secondary flex items-center px-3">
            </div>
          </div>
          <div class="grid grid-cols-4 gap-3">
            {gsScores.map((score, i) => {
              const { color, offset } = scoreCircle(score);
              return (
                <div class="flex flex-col items-center gap-2">
                  <svg viewBox="0 0 50 50" class="w-12 h-12">
                    <circle cx="25" cy="25" r="22" fill="none" stroke="rgb(255 255 255 / 5%)" stroke-width="3.5"/>
                    <circle cx="25" cy="25" r="22" fill="none" stroke={color} stroke-width="3.5" stroke-dasharray={circ} stroke-dashoffset={offset} stroke-linecap="round" transform="rotate(-90 25 25)"/>
                    <text x="25" y="29" text-anchor="middle" fill={color} font-size="11" font-weight="600">{score}</text>
                  </svg>
                  <p class="text-label text-foreground-dimmer fw-400 text-center leading-tight">{labels[i]}</p>
                </div>
              );
            })}
          </div>
        </div>
        <h3 class="text-body fw-590 text-foreground tracking-[-0.015em] mb-2">{c.labelB}</h3>
        <p class="text-label text-muted-foreground leading-[1.65] fw-400">{c.captionB}</p>
      </div>

    </div>
  </div>
</section>
