---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  items: FaqItem[];
}

const { title, items } = Astro.props;
---

<section class="px-6 md:px-10 border-t border-white/6">
  <div class="max-w-7xl mx-auto py-24">
    <h2 class="text-section-heading fw-510 leading-[1.08] tracking-[-0.04em] text-foreground mb-16">
      {title}
    </h2>
    <div class="flex flex-col divide-y divide-white/6">
      {items.map((item) => (
        <details class="group py-6 cursor-pointer">
          <summary class="flex items-center justify-between gap-8 list-none">
            <h3 class="text-body fw-510 text-foreground tracking-[-0.015em]">
              {item.question}
            </h3>
            <div class="flex-shrink-0 w-5 h-5 rounded-full border border-white/15 flex items-center justify-center transition-transform group-open:rotate-45">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <path d="M12 5v14M5 12h14"/>
              </svg>
            </div>
          </summary>
          <p class="mt-4 text-body text-muted-foreground leading-[1.7] fw-400 max-w-3xl">
            {item.answer}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>
