---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

const content = {
  de: {
    heading: "Was wir liefern.",
    description: "Von einem einzigen Social-Post bis zum vollständigen Grafikpaket. Alles custom, alles auf deine Marke zugeschnitten.",
    items: [
      {
        title: "Social Media Designs",
        description: "Posts, Stories und Thumbnails für Instagram, LinkedIn, Facebook. Optimiert für jede Plattform.",
        icon: "social",
      },
      {
        title: "Werbebanner & Ads",
        description: "Display-Ads und Social-Ad-Grafiken in allen gängigen Formaten. Auf Conversion ausgerichtet.",
        icon: "ads",
      },
      {
        title: "Illustrationen",
        description: "Individuelle Illustrationen für Website, Kampagnen oder Präsentationen. Von Icon bis Szene.",
        icon: "illustration",
      },
      {
        title: "Brand Templates",
        description: "Wiederverwendbare Vorlagen für Kommunikation und Marketing. Einmal aufgesetzt, dauerhaft nutzbar.",
        icon: "template",
      },
      {
        title: "Präsentationen",
        description: "Pitch Decks und Unternehmensfolien in PowerPoint oder Keynote. Professionell und einheitlich.",
        icon: "presentation",
      },
      {
        title: "Icons & UI-Elemente",
        description: "Custom Icon-Sets und Interface-Grafiken, die zu deiner Marke und deinem Produkt passen.",
        icon: "icons",
      },
    ],
  },
  en: {
    heading: "What we deliver.",
    description: "From a single social post to a complete graphics package. All custom, all tailored to your brand.",
    items: [
      {
        title: "Social media designs",
        description: "Posts, stories, and thumbnails for Instagram, LinkedIn, Facebook. Optimised for every platform.",
        icon: "social",
      },
      {
        title: "Advertising banners & ads",
        description: "Display ads and social ad graphics in all common formats. Built for conversion.",
        icon: "ads",
      },
      {
        title: "Illustrations",
        description: "Custom illustrations for websites, campaigns, or presentations. From icon to full scene.",
        icon: "illustration",
      },
      {
        title: "Brand templates",
        description: "Reusable templates for communication and marketing. Set up once, used permanently.",
        icon: "template",
      },
      {
        title: "Presentations",
        description: "Pitch decks and company slides in PowerPoint or Keynote. Professional and consistent.",
        icon: "presentation",
      },
      {
        title: "Icons & UI elements",
        description: "Custom icon sets and interface graphics that match your brand and your product.",
        icon: "icons",
      },
    ],
  },
};

const c = locale === "de" ? content.de : content.en;
---

<section class="border-t border-[rgba(255,255,255,0.06)] px-6 md:px-10">
  <div class="max-w-7xl mx-auto">
    <div class="py-28 flex flex-col lg:flex-row lg:justify-between gap-6 lg:gap-16">
      <h2 class="text-section-heading fw-510 leading-[1.08] tracking-[-0.04em] text-[#f7f8f8] lg:max-w-[44%]">
        {c.heading}
      </h2>
      <p class="text-body text-[#8a8f98] leading-[1.7] fw-400 lg:max-w-[42%] flex items-center">
        {c.description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 mb-16">
      {c.items.map((item) => (
        <div class="py-8 flex flex-col gap-5">

          <!-- Icon -->
          <div class="w-9 h-9 flex items-center justify-center text-[#f7f8f8]">
            {item.icon === "social" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5" y="2" width="14" height="20" rx="2"/>
                <line x1="12" y1="18" x2="12.01" y2="18"/>
              </svg>
            )}
            {item.icon === "ads" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
                <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
              </svg>
            )}
            {item.icon === "illustration" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 19l7-7 3 3-7 7-3-3z"/>
                <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
                <path d="M2 2l7.586 7.586"/>
                <circle cx="11" cy="11" r="2"/>
              </svg>
            )}
            {item.icon === "template" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18"/>
                <path d="M9 21V9"/>
              </svg>
            )}
            {item.icon === "presentation" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            )}
            {item.icon === "icons" && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/>
                <rect x="14" y="14" width="7" height="7" rx="1"/>
              </svg>
            )}
          </div>

          <div>
            <h3 class="text-body fw-590 text-[#f7f8f8] tracking-[-0.015em] mb-2">{item.title}</h3>
            <p class="text-label text-[#62666d] leading-[1.7] fw-400">{item.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
