---
interface Step {
  number: string;
  title: string;
  description: string;
}

interface Props {
  label: string;
  title: string;
  subtitle: string;
  description: string;
  steps: Step[];
}

const { label, title, subtitle, description, steps } = Astro.props;
---

<section class="px-6 md:px-10 py-32 border-t border-[rgba(255,255,255,0.06)]">
  <div class="max-w-7xl mx-auto">

    <!-- 2-col intro -->
    <div class="flex flex-col lg:flex-row lg:justify-between gap-8 lg:gap-16 mb-20">
      <h2 class="text-[clamp(1.75rem,3vw,2.5rem)] fw-510 leading-[1.08] tracking-[-0.04em] text-[#f7f8f8] lg:max-w-[44%]">
        {title}<br />{subtitle}
      </h2>
      <p class="text-[16px] text-[#8a8f98] leading-[1.7] fw-400 lg:max-w-[42%] flex items-center">
        {description}
      </p>
    </div>

    <!-- Steps: 3 equal columns, top-border accent, no connecting line -->
    <div class="grid grid-cols-1 md:grid-cols-3">
      {
        steps.map((step, i) => (
          <div class={`flex flex-col pt-8 pb-4 border-t-2 border-[rgba(255,255,255,0.1)] ${i < steps.length - 1 ? "md:pr-12" : ""} ${i > 0 ? "md:pl-12 md:border-l md:border-l-[rgba(255,255,255,0.06)] mt-8 md:mt-0" : ""}`}>
            <p class="text-[11px] fw-510 text-[#3d4047] tracking-[0.1em] mb-6">{step.number}</p>
            <h3 class="text-[15px] fw-590 text-[#f7f8f8] tracking-[-0.015em] mb-3">
              {step.title}
            </h3>
            <p class="text-[13px] text-[#62666d] leading-[1.65] fw-400">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>

  </div>
</section>
