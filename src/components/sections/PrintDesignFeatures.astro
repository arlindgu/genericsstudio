---
import { useTranslations } from "@/i18n/utils";

interface Props { locale?: string }
const { locale = "de" } = Astro.props;
const { tRaw } = useTranslations(locale);

type Item = { number: string; title: string; spec: string; description: string };
type FeaturesContent = { heading: string; description: string; items: Item[] };
const content = tRaw<FeaturesContent>("sections.printdesign.features");
---

<section class="px-6 md:px-10 border-t border-white/6">
  <div class="max-w-7xl mx-auto">

    <div class="py-28 flex flex-col lg:flex-row lg:justify-between gap-6 lg:gap-16">
      <h2 class="text-section-heading fw-510 leading-[1.08] tracking-[-0.04em] text-foreground lg:max-w-[44%]">
        {content.heading}
      </h2>
      <p class="text-body text-muted-foreground leading-[1.7] fw-400 lg:max-w-[42%] flex items-center">
        {content.description}
      </p>
    </div>

    <div class="border-t border-white/6 mb-16">
      {content.items.map((item) => (
        <div class="flex items-start gap-8 py-8 border-b border-white/6">
          <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-x-16 gap-y-2 flex-1">
            <div>
              <h3 class="text-body fw-590 text-foreground tracking-[-0.02em] mb-1.5">{item.title}</h3>
              <span class="text-label fw-400 text-muted-foreground tracking-[0.03em]">{item.spec}</span>
            </div>
            <p class="text-body text-muted-foreground leading-[1.75] fw-400">{item.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
