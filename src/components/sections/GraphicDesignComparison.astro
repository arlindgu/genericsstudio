---
interface Props {
  locale: string;
}

const { locale } = Astro.props;

const de = {
  heading: "Warum kein Canva?",
  description: "Canva-Templates sehen aus wie Canva-Templates. Jeder erkennt sie. Custom-Design macht den Unterschied zwischen scrollen und stoppen.",
  labelA: "Canva / Stock-Template",
  labelB: "Custom Design",
  captionA: "Vorgefertigte Vorlage, Stock-Icons und generische Farbverläufe. Identisch mit zehntausend anderen Posts. Kein Wiedererkennungswert.",
  captionB: "Jedes Element auf deine Marke abgestimmt. Eigene Typografie, eigene Farben, eigene Bildsprache. Unverwechselbar.",
  templateBadge: "Vorlage",
  customBadge: "Custom",
  templateStats: [
    { label: "Einzigartigkeit", value: "0 %" },
    { label: "Markenkonformität", value: "Keine" },
    { label: "Verwendung", value: "50.000×" },
  ],
  customStats: [
    { label: "Einzigartigkeit", value: "100 %" },
    { label: "Markenkonformität", value: "Voll" },
    { label: "Verwendung", value: "1×" },
  ],
};

const en = {
  heading: "Why not Canva?",
  description: "Canva templates look like Canva templates. Everyone recognises them. Custom design is the difference between scrolling and stopping.",
  labelA: "Canva / stock template",
  labelB: "Custom design",
  captionA: "Pre-made template, stock icons, and generic gradients. Identical to tens of thousands of other posts. Zero recognition value.",
  captionB: "Every element aligned to your brand. Your own typography, colours, and visual language. Unmistakable.",
  templateBadge: "Template",
  customBadge: "Custom",
  templateStats: [
    { label: "Uniqueness", value: "0 %" },
    { label: "Brand conformity", value: "None" },
    { label: "Usage", value: "50,000×" },
  ],
  customStats: [
    { label: "Uniqueness", value: "100 %" },
    { label: "Brand conformity", value: "Full" },
    { label: "Usage", value: "1×" },
  ],
};

const c = locale === "de" ? de : en;
---

<section class="px-6 md:px-10">
  <div class="max-w-7xl mx-auto">

    <div class="py-20 flex flex-col lg:flex-row lg:justify-between gap-8 lg:gap-16">
      <h2 class="text-[clamp(1.75rem,3vw,2.5rem)] fw-510 leading-[1.08] tracking-[-0.04em] text-[#f7f8f8] lg:max-w-[44%]">
        {c.heading}
      </h2>
      <p class="text-[16px] text-[#8a8f98] leading-[1.7] fw-400 lg:max-w-[42%] flex items-center">
        {c.description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-[rgba(255,255,255,0.06)] pt-10 pb-10">

      <!-- Panel A: Template -->
      <div>
        <div class="bg-[#0d0e0f] rounded-[8px] p-6 mb-6 border border-[rgba(255,255,255,0.05)]">
          <div class="rounded-[6px] bg-gradient-to-br from-[#1a1a2e] to-[#16213e] p-5 mb-5 relative overflow-hidden">
            <div class="absolute top-3 right-3">
              <span class="px-2 py-0.5 rounded-[4px] bg-[rgba(255,255,255,0.06)] text-[9px] text-[#3d4047] fw-510">{c.templateBadge}</span>
            </div>
            <div class="w-8 h-8 rounded-full bg-[rgba(255,255,255,0.06)] mb-3 flex items-center justify-center">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <path d="m21 15-5-5L5 21"/>
              </svg>
            </div>
            <div class="h-3 w-24 rounded-[2px] bg-[rgba(255,255,255,0.08)] mb-2"></div>
            <div class="h-2 w-32 rounded-[2px] bg-[rgba(255,255,255,0.05)] mb-1"></div>
            <div class="h-2 w-20 rounded-[2px] bg-[rgba(255,255,255,0.05)]"></div>
          </div>
          <div class="flex flex-col gap-2">
            {c.templateStats.map(stat => (
              <div class="flex justify-between items-center py-1.5 border-b border-[rgba(255,255,255,0.04)] last:border-0">
                <span class="text-[11px] text-[#3d4047] fw-400">{stat.label}</span>
                <span class="text-[11px] text-[#ff4e43] fw-510">{stat.value}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <div class="w-2 h-2 rounded-full bg-[#ff4e43] flex-shrink-0"></div>
          <h3 class="text-[15px] fw-590 text-[#f7f8f8] tracking-[-0.015em]">{c.labelA}</h3>
        </div>
        <p class="text-[13px] text-[#62666d] leading-[1.65] fw-400">{c.captionA}</p>
      </div>

      <!-- Panel B: Custom -->
      <div>
        <div class="bg-[#0d0e0f] rounded-[8px] p-6 mb-6 border border-[rgba(255,255,255,0.05)]">
          <div class="rounded-[6px] bg-[#0a0b12] p-5 mb-5 relative overflow-hidden border border-[rgba(94,106,210,0.15)]">
            <div class="absolute top-3 right-3">
              <span class="px-2 py-0.5 rounded-[4px] bg-[rgba(94,106,210,0.12)] text-[9px] text-[#5e6ad2] fw-510">{c.customBadge}</span>
            </div>
            <div class="w-8 h-8 rounded-[6px] bg-[#5e6ad2] mb-3 flex items-center justify-center">
              <span class="text-[12px] fw-590 text-white">G</span>
            </div>
            <div class="h-3 w-28 rounded-[2px] bg-[rgba(94,106,210,0.3)] mb-2"></div>
            <div class="h-2 w-36 rounded-[2px] bg-[rgba(247,248,248,0.08)] mb-1"></div>
            <div class="h-2 w-24 rounded-[2px] bg-[rgba(247,248,248,0.06)]"></div>
          </div>
          <div class="flex flex-col gap-2">
            {c.customStats.map(stat => (
              <div class="flex justify-between items-center py-1.5 border-b border-[rgba(255,255,255,0.04)] last:border-0">
                <span class="text-[11px] text-[#3d4047] fw-400">{stat.label}</span>
                <span class="text-[11px] text-[#0cce6b] fw-510">{stat.value}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <div class="w-2 h-2 rounded-full bg-[#0cce6b] flex-shrink-0"></div>
          <h3 class="text-[15px] fw-590 text-[#f7f8f8] tracking-[-0.015em]">{c.labelB}</h3>
        </div>
        <p class="text-[13px] text-[#62666d] leading-[1.65] fw-400">{c.captionB}</p>
      </div>

    </div>
  </div>
</section>
