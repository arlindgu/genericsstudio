---
import { useTranslations } from "@/i18n/utils";

interface Props { locale?: string }
const { locale = "de" } = Astro.props;
const { tRaw } = useTranslations(locale);

type Stat = { label: string; value: string };
type ComparisonContent = {
  heading: string; description: string;
  labelA: string; labelB: string;
  captionA: string; captionB: string;
  templateBadge: string; customBadge: string;
  templateStats: Stat[]; customStats: Stat[];
};
const c = tRaw<ComparisonContent>("sections.graphicdesign.comparison");
---

<section class="px-6 md:px-10">
  <div class="max-w-7xl mx-auto">

    <div class="py-28 flex flex-col lg:flex-row lg:justify-between gap-8 lg:gap-16">
      <h2 class="text-section-heading fw-510 leading-[1.08] tracking-[-0.04em] text-foreground lg:max-w-[44%]">
        {c.heading}
      </h2>
      <p class="text-body text-muted-foreground leading-[1.7] fw-400 lg:max-w-[42%] flex items-center">
        {c.description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-white/6 pt-10 pb-10">

      <!-- Panel A: Template -->
      <div>
        <div class="bg-surface rounded-[8px] p-6 mb-6 border border-white/5">
          <div class="rounded-[6px] bg-gradient-to-br from-mockup-from to-mockup-to p-5 mb-5 relative overflow-hidden">
            <div class="absolute top-3 right-3">
              <span class="px-2 py-0.5 rounded-[4px] bg-white/6 text-label text-foreground-dimmer fw-510">{c.templateBadge}</span>
            </div>
            <div class="w-8 h-8 rounded-full bg-white/6 mb-3 flex items-center justify-center">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgb(255 255 255 / 20%)" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <path d="m21 15-5-5L5 21"/>
              </svg>
            </div>
            <div class="h-3 w-24 rounded-[2px] bg-white/8 mb-2"></div>
            <div class="h-2 w-32 rounded-[2px] bg-white/5 mb-1"></div>
            <div class="h-2 w-20 rounded-[2px] bg-white/5"></div>
          </div>
          <div class="flex flex-col gap-2">
            {c.templateStats.map(stat => (
              <div class="flex justify-between items-center py-1.5 border-b border-white/4 last:border-0">
                <span class="text-label text-muted-foreground fw-400">{stat.label}</span>
                <span class="text-label text-destructive fw-510">{stat.value}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <div class="w-2 h-2 rounded-full bg-destructive flex-shrink-0"></div>
          <h3 class="text-body fw-590 text-foreground tracking-[-0.015em]">{c.labelA}</h3>
        </div>
        <p class="text-label text-muted-foreground leading-[1.65] fw-400">{c.captionA}</p>
      </div>

      <!-- Panel B: Custom -->
      <div>
        <div class="bg-surface rounded-[8px] p-6 mb-6 border border-white/5">
          <div class="rounded-[6px] bg-surface-dark p-5 mb-5 relative overflow-hidden border border-primary/15">
            <div class="absolute top-3 right-3">
              <span class="px-2 py-0.5 rounded-[4px] bg-primary/12 text-label text-primary fw-510">{c.customBadge}</span>
            </div>
            <div class="w-8 h-8 rounded-[6px] bg-primary mb-3 flex items-center justify-center">
              <span class="text-label fw-590 text-white">G</span>
            </div>
            <div class="h-3 w-28 rounded-[2px] bg-primary/30 mb-2"></div>
            <div class="h-2 w-36 rounded-[2px] bg-foreground/8 mb-1"></div>
            <div class="h-2 w-24 rounded-[2px] bg-foreground/6"></div>
          </div>
          <div class="flex flex-col gap-2">
            {c.customStats.map(stat => (
              <div class="flex justify-between items-center py-1.5 border-b border-white/4 last:border-0">
                <span class="text-label text-muted-foreground fw-400">{stat.label}</span>
                <span class="text-label text-success fw-510">{stat.value}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <div class="w-2 h-2 rounded-full bg-success flex-shrink-0"></div>
          <h3 class="text-body fw-590 text-foreground tracking-[-0.015em]">{c.labelB}</h3>
        </div>
        <p class="text-label text-muted-foreground leading-[1.65] fw-400">{c.captionB}</p>
      </div>

    </div>
  </div>
</section>
