---
import { useTranslations } from "@/i18n/utils";

interface Props { locale?: string }
const { locale = "de" } = Astro.props;
const { tRaw } = useTranslations(locale);

type Spec = { label: string; value: string; ok: boolean };
type ComparisonContent = {
  heading: string; description: string;
  labelA: string; labelB: string;
  captionA: string; captionB: string;
  specsA: Spec[]; specsB: Spec[];
};
const c = tRaw<ComparisonContent>("sections.printdesign.comparison");
---

<section class="px-6 md:px-10">
  <div class="max-w-7xl mx-auto">

    <div class="py-28 flex flex-col lg:flex-row lg:justify-between gap-8 lg:gap-16">
      <h2 class="text-section-heading fw-510 leading-[1.08] tracking-[-0.04em] text-foreground lg:max-w-[44%]">
        {c.heading}
      </h2>
      <p class="text-body text-muted-foreground leading-[1.7] fw-400 lg:max-w-[42%] flex items-center">
        {c.description}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-white/6 pt-10 pb-10">

      <!-- Panel A: Wrong file -->
      <div>
        <div class="bg-surface rounded-[8px] p-6 mb-6 border border-white/5">
          <div class="rounded-[6px] border border-dashed border-destructive/30 p-4 mb-5 relative">
            <div class="absolute -top-2 -right-2 w-5 h-5 rounded-full bg-destructive flex items-center justify-center">
              <span class="text-label text-foreground fw-590">!</span>
            </div>
            <div class="h-16 rounded-[4px] mb-3 overflow-hidden relative">
              <div class="absolute inset-0 bg-gradient-to-r from-none via-mockup-blue to-none opacity-60"></div>
              <div class="absolute inset-1 flex items-center justify-center">
                <div class="h-2 w-20 rounded bg-white/10"></div>
              </div>
            </div>
            <p class="text-label text-destructive fw-510 text-center">document_final_v3.png</p>
          </div>
          <div class="flex flex-col">
            {c.specsA.map(spec => (
              <div class="flex justify-between items-center py-2 border-b border-white/4 last:border-0">
                <span class="text-label text-muted-foreground fw-400">{spec.label}</span>
                <div class="flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-destructive"></div>
                  <span class="text-label text-destructive fw-510">{spec.value}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <div class="w-2 h-2 rounded-full bg-destructive flex-shrink-0"></div>
          <h3 class="text-body fw-590 text-foreground tracking-[-0.015em]">{c.labelA}</h3>
        </div>
        <p class="text-label text-muted-foreground leading-[1.65] fw-400">{c.captionA}</p>
      </div>

      <!-- Panel B: Professional prep -->
      <div>
        <div class="bg-surface rounded-[8px] p-6 mb-6 border border-white/5">
          <div class="rounded-[6px] border border-success/20 p-4 mb-5 relative">
            <div class="absolute -top-2 -right-2 w-5 h-5 rounded-full bg-success flex items-center justify-center">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div class="h-16 rounded-[4px] mb-3 overflow-hidden relative bg-surface-dark">
              <div class="absolute inset-0 border border-dashed border-success/20"></div>
              <div class="absolute inset-[3px] bg-primary/8 flex items-center justify-center">
                <div class="flex items-center gap-2">
                  <div class="w-5 h-5 rounded-[3px] bg-primary flex items-center justify-center">
                    <span class="text-label fw-590 text-foreground">G</span>
                  </div>
                  <div class="h-2 w-12 rounded bg-foreground/10"></div>
                </div>
              </div>
            </div>
            <p class="text-label text-success fw-510 text-center">flyer_druckfertig_CMYK.pdf</p>
          </div>
          <div class="flex flex-col">
            {c.specsB.map(spec => (
              <div class="flex justify-between items-center py-2 border-b border-white/4 last:border-0">
                <span class="text-label text-muted-foreground fw-400">{spec.label}</span>
                <div class="flex items-center gap-1.5">
                  <div class="w-1.5 h-1.5 rounded-full bg-success"></div>
                  <span class="text-label text-success fw-510">{spec.value}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <div class="w-2 h-2 rounded-full bg-success flex-shrink-0"></div>
          <h3 class="text-body fw-590 text-foreground tracking-[-0.015em]">{c.labelB}</h3>
        </div>
        <p class="text-label text-muted-foreground leading-[1.65] fw-400">{c.captionB}</p>
      </div>

    </div>
  </div>
</section>
