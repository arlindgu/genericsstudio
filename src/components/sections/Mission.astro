---
interface Benefit {
  number: string;
  title: string;
  description: string;
}

interface Props {
  label: string;
  title: string;
  subtitle: string;
  description: string;
  benefits: Benefit[];
}

const { label, title, subtitle, description, benefits } = Astro.props;
---

<section class="px-6 md:px-10 pt-40 pb-40 border-t border-white/6">
  <div class="max-w-7xl mx-auto">

    <!-- 2-col intro -->
    <div class="flex flex-col lg:flex-row lg:justify-between gap-8 lg:gap-16 mb-20">
      <h2 class="text-section-heading fw-510 leading-[1.08] tracking-[-0.04em] text-foreground lg:max-w-[44%]">
        {title}<br />{subtitle}
      </h2>
      <p class="text-body text-muted-foreground leading-[1.7] fw-400 lg:max-w-[42%] flex items-center">
        {description}
      </p>
    </div>

    <!-- Benefits: simple grid, no cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-16 gap-y-12 border-t border-white/6 pt-16">
      {
        benefits.map((b) => (
          <div>
            <p class="text-label fw-510 text-foreground-dimmer tracking-[0.1em] mb-4">{b.number}</p>
            <h3 class="text-body fw-590 text-foreground tracking-[-0.01em] mb-2.5">{b.title}</h3>
            <p class="text-label text-muted-foreground leading-[1.6] fw-400">{b.description}</p>
          </div>
        ))
      }
    </div>

  </div>
</section>
