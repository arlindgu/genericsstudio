---
interface Props {
  service: "webdesign" | "branding" | "graphicdesign" | "printdesign";
  label?: string;
}

const { service, label } = Astro.props;

const serviceMap = {
  webdesign: {
    href: "/webdesign",
    default: "Website anfragen",
    title: "Individuelles Webdesign aus Wil SG",
    description: "Schnell geladen, lokal gefunden, individuell gestaltet. Ab 600 CHF.",
  },
  branding: {
    href: "/branding",
    default: "Branding anfragen",
    title: "Branding & Logodesign aus Wil SG",
    description: "Logo, Farben, Typografie und Brand Guidelines. Ab 300 CHF.",
  },
  graphicdesign: {
    href: "/graphicdesign",
    default: "Grafikdesign anfragen",
    title: "Grafikdesign aus Wil SG",
    description: "Social Media, Werbegrafiken, Illustrationen. Ab 80 CHF.",
  },
  printdesign: {
    href: "/printdesign",
    default: "Printdesign anfragen",
    title: "Individuelles Printdesign aus Wil SG",
    description: "Druckfertige Dateien für Flyer, Visitenkarten und mehr. Ab 100 CHF.",
  },
};

const s = serviceMap[service];
const ctaLabel = label ?? s.default;
---

<aside class="mx-6 md:mx-10 my-12 rounded-[12px] border border-white/8 bg-surface p-8 md:p-10">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
    <div>
      <p class="text-label fw-510 text-primary tracking-[0.08em] uppercase mb-2">Weiterführend</p>
      <h3 class="text-step-heading fw-510 text-foreground tracking-[-0.03em] leading-tight mb-2">
        {s.title}
      </h3>
      <p class="text-body text-muted-foreground fw-400 leading-[1.6]">
        {s.description}
      </p>
    </div>
    <a
      href={s.href}
      class="flex-shrink-0 inline-flex items-center gap-2 px-5 py-2.5 rounded-[8px] bg-foreground text-background text-body fw-510 hover:bg-foreground/90 transition-colors"
    >
      {ctaLabel}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</aside>
