---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { useTranslations } from "@/i18n/utils";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  return [{ params: { locale: "de" } }, { params: { locale: "en" } }];
}

const { locale } = Astro.params;
const { t } = useTranslations(locale);

const collectionKey = locale === "de" ? "blog-de" : "blog-en";
const posts = (await getCollection(collectionKey)).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout
  title={t("blog.meta.title")}
  description={t("blog.meta.description")}
  locale={locale}
>
  <main>
    <PageHeader
      title={t("blog.header.title")}
      description={t("blog.header.description")}
    />

    <section class="py-16 px-6 md:px-10">
      <div class="max-w-7xl mx-auto">
        {
          posts.length === 0 ? (
            <p class="text-[#8a8f98]">No posts yet.</p>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {posts.map((post) => (
                <a
                  href={`/${locale}/blog/${post.id}`}
                  class="group flex flex-col p-6 bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-[8px] hover:bg-[rgba(255,255,255,0.04)] hover:border-[rgba(255,255,255,0.12)] transition-all duration-200"
                >
                  <div class="flex items-center gap-2 mb-4">
                    <span class="text-xs font-[510] text-[#62666d] bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.06)] rounded-full px-2.5 py-0.5">
                      {post.data.category}
                    </span>
                    <span class="text-xs text-[#62666d]">
                      {post.data.readingTime} {t("blog.readingTime")}
                    </span>
                  </div>
                  <h2 class="text-base font-[590] text-[#f7f8f8] tracking-[-0.24px] mb-2 group-hover:text-white transition-colors leading-snug">
                    {post.data.title}
                  </h2>
                  <p class="text-sm text-[#8a8f98] leading-relaxed flex-1 mb-4">
                    {post.data.description}
                  </p>
                  <p class="text-xs text-[#62666d]">
                    {new Date(post.data.date).toLocaleDateString(
                      locale === "de" ? "de-CH" : "en-GB",
                      { year: "numeric", month: "long", day: "numeric" }
                    )}
                  </p>
                </a>
              ))}
            </div>
          )
        }
      </div>
    </section>
  </main>
</Layout>
