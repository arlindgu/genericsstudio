---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import BrandingComparison from "@/components/sections/BrandingComparison.astro";
import BrandingFeatures from "@/components/sections/BrandingFeatures.astro";
import ServicePricing from "@/components/sections/ServicePricing.astro";
import { useTranslations } from "@/i18n/utils";

export function getStaticPaths() {
  return [{ params: { locale: "de" } }, { params: { locale: "en" } }];
}

const { locale } = Astro.params;
const { t, tRaw } = useTranslations(locale);

type Plan = { title: string; description: string; price: string; features: string[] };
type PricingCta = { title: string; description: string; button: string };

const siteUrl = "https://generics.studio";
const localePath = locale === "de" ? siteUrl : `${siteUrl}/en`;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: locale === "de" ? "Branding & Logodesign" : "Branding & Logo Design",
  serviceType: "Branding",
  description: t("pages.branding.meta.description"),
  provider: { "@id": `${siteUrl}/#organization` },
  areaServed: [
    { "@type": "City", name: "Wil" },
    { "@type": "AdministrativeArea", name: "Kanton St. Gallen" },
    { "@type": "Country", name: "Schweiz" },
  ],
  offers: { "@type": "AggregateOffer", lowPrice: "300", priceCurrency: "CHF", offerCount: "3" },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/${locale}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: locale === "de" ? "Branding" : "Branding",
      item: `${siteUrl}/${locale}/branding`,
    },
  ],
};
---

<Layout
  title={t("pages.branding.meta.title")}
  description={t("pages.branding.meta.description")}
  locale={locale}
  schema={[serviceSchema, breadcrumbSchema]}
>
  <main>
    <PageHeader
      title={t("pages.branding.header.title")}
      description={t("pages.branding.header.description")}
    />
    <BrandingComparison locale={locale} />
    <BrandingFeatures locale={locale} />
    <ServicePricing
      title={t("pages.branding.pricing.title")}
      description={t("pages.branding.pricing.description")}
      note={t("pages.branding.pricing.note")}
      cta={tRaw<PricingCta>("pages.branding.pricing.cta")}
      plans={tRaw<Plan[]>("pages.branding.pricing.plans")}
    />
  </main>
</Layout>
