---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { useTranslations } from "@/i18n/utils";

export function getStaticPaths() {
  return [{ params: { locale: "de" } }, { params: { locale: "en" } }];
}

const { locale } = Astro.params;
const { t, tRaw } = useTranslations(locale);

type ContactOption = {
  number: string;
  label: string;
  title: string;
  description: string;
  href: string;
  external: boolean;
};

const options = tRaw<ContactOption[]>("contact.options");

const siteUrl = "https://generics.studio";

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: locale === "de" ? "Kontakt – Generics Studio" : "Contact – Generics Studio",
  url: `${siteUrl}/${locale}/contact`,
  isPartOf: { "@id": `${siteUrl}/#website` },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/${locale}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: locale === "de" ? "Kontakt" : "Contact",
      item: `${siteUrl}/${locale}/contact`,
    },
  ],
};
---

<Layout
  title={t("contact.meta.title")}
  description={t("contact.meta.description")}
  locale={locale}
  schema={[contactSchema, breadcrumbSchema]}
>
  <main>
    <PageHeader
      title={t("contact.header.title")}
      description={t("contact.header.description")}
    />

    <section class="py-24 px-6 md:px-10">
      <div class="max-w-7xl mx-auto">
        <div class="mb-16 max-w-xl">
          <p class="text-[#62666d] text-xs font-[510] uppercase tracking-[0.12em] mb-3">
            {t("contact.label")}
          </p>
          <h2
            class="text-3xl md:text-4xl font-[510] text-[#f7f8f8] tracking-[-0.704px] leading-tight whitespace-pre-line mb-4"
          >
            {t("contact.title")}
          </h2>
          <p class="text-[#8a8f98] text-base leading-relaxed">
            {t("contact.description")}
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {
            options.map((option) => (
              <a
                href={option.href}
                target={option.external ? "_blank" : undefined}
                rel={option.external ? "noopener noreferrer" : undefined}
                class="group flex flex-col p-8 bg-[rgba(255,255,255,0.02)] border border-[rgba(255,255,255,0.08)] rounded-[12px] hover:bg-[rgba(255,255,255,0.04)] hover:border-[rgba(255,255,255,0.12)] transition-all duration-200"
              >
                <span class="text-xs font-[510] text-[#62666d] tracking-[0.1em] block mb-4">
                  {option.number}
                </span>
                <p class="text-xs font-[510] text-[#62666d] uppercase tracking-[0.1em] mb-2">
                  {option.label}
                </p>
                <p class="text-lg font-[590] text-[#f7f8f8] tracking-[-0.288px] mb-2 group-hover:text-white transition-colors">
                  {option.title}
                </p>
                <p class="text-sm text-[#8a8f98] leading-relaxed">
                  {option.description}
                </p>
                <div class="mt-6 flex items-center gap-2 text-sm font-[510] text-[#62666d] group-hover:text-[#7170ff] transition-colors">
                  {option.external ? "Open ↗" : "→"}
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
